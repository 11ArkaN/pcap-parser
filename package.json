{
  "name": "pcap-analyzer",
  "version": "1.0.4",
  "description": "Aplikacja do analizy plikow PCAP z Wiresharka",
  "main": "dist/main.js",
  "scripts": {
    "start": "bun run build && electron .",
    "dev": "bun run build && electron .",
    "build:main": "bun build ./main.ts --outfile ./dist/main.js --target node --format cjs --external electron && bun build ./preload.ts --outfile ./dist/preload.js --target node --format cjs --external electron",
    "build:renderer": "bun build ./src/index.tsx --outdir ./dist --target browser",
    "copy:styles": "node -e \"require('fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "build": "bun run build:main && bun run build:renderer && bun run copy:styles",
    "test": "bun test",
    "test:captures": "bun test tests/captures-table-data.test.ts",
    "runtime:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prepare_release_runtime.ps1",
    "dist": "bun run build && electron-builder --win nsis",
    "dist:internal": "bun run build && electron-builder --win nsis --config electron-builder.internal.cjs",
    "sidecar:install-deps": "python -m pip install -r sidecar/requirements.txt"
  },
  "dependencies": {
    "papaparse": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "buffer": "^6.0.3",
    "bun-types": "^1.3.10",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pcap.analyzer",
    "productName": "PCAP Analyzer",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecar",
        "to": "sidecar",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/procmon",
        "to": "procmon",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "include": "build/installer.internal.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
